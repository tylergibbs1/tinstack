{
  "name": "tinstack",
  "version": "0.1.0",
  "description": "A lightweight AWS local emulator in TypeScript + Bun",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "tinstack": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build": "bun build --compile src/index.ts --outfile tinstack",
    "typecheck": "tsc --noEmit"
  },
