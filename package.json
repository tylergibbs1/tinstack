{
  "name": "tinstack",
  "version": "0.1.0",
  "description": "A lightweight AWS local emulator in TypeScript + Bun",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "tinstack": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build": "bun build --compile src/index.ts --outfile tinstack",
    "typecheck": "tsc --noEmit"
  },
  "private": true,
  "devDependencies": {
    "@aws-sdk/client-cloudwatch": "^3.1014.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1014.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1014.0",
    "@aws-sdk/client-dynamodb": "^3.800.0",
    "@aws-sdk/client-dynamodb-streams": "^3.1014.0",
    "@aws-sdk/client-eventbridge": "^3.1014.0",
    "@aws-sdk/client-iam": "^3.1014.0",
    "@aws-sdk/client-kinesis": "^3.1014.0",
    "@aws-sdk/client-kms": "^3.1014.0",
    "@aws-sdk/client-s3": "^3.800.0",
    "@aws-sdk/client-secrets-manager": "^3.800.0",
    "@aws-sdk/client-sns": "^3.1014.0",
    "@aws-sdk/client-sqs": "^3.800.0",
    "@aws-sdk/client-ssm": "^3.800.0",
    "@aws-sdk/client-sts": "^3.1014.0",
    "@aws-sdk/lib-dynamodb": "^3.800.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@smithy/node-http-handler": "^4.5.0",
    "@types/bun": "^1.3.11"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
